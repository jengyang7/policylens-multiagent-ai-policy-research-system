# Copy to .env and fill in values

# Postgres (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://research:research@localhost:5432/research

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: debate mode's cross-provider debaters. Models from providers
# whose key is unset are hidden in the UI; debate then falls back to OpenAI.
# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
# Google AI — https://aistudio.google.com/apikey
# GOOGLE_API_KEY=

# Search providers — default order when keys are present:
# Tavily (default broad search), Exa (deep semantic), SerpAPI (Google fallback).
# Override with SEARCH_PROVIDERS=tavily,exa,serpapi if you want explicit ordering.
# Tavily — https://tavily.com
TAVILY_API_KEY=
# Exa — https://dashboard.exa.ai/api-keys
EXA_API_KEY=
# SerpAPI — https://serpapi.com/manage-api-key
SERPAPI_API_KEY=
# Optional SerpAPI Google localization.
# SERPAPI_GL=sg
# SERPAPI_HL=en
# SERPAPI_LOCATION=Singapore
# SEARCH_PROVIDERS=tavily,exa,serpapi

# Page extraction/crawling — Firecrawl scrape endpoint, falls back to local fetch if unset/fails.
# Firecrawl — https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v2/scrape

# CORS — comma-separated list of allowed frontend origins (defaults to localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Optional: LangSmith tracing — traces every LangChain LLM call (plan, debate,
# synthesize, eval judges, ...), not just the eval harness.
# https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=deep-research-eval
